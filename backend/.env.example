# Database (local Docker for dev, Neon for prod)
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/pranavmeds

# Redis (local Docker for dev, Upstash for prod)
REDIS_URL=redis://localhost:6379/0

# Meilisearch (local Docker for dev)
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=dev-key

# App
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=["http://localhost:3000"]
